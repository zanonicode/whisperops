# Application-platform-layer charts (kagent + Crossplane + Kyverno + LGTM
# + OTel Collector). Installed AFTER the IDP layer (idpbuilder/CNOE) is up.
#
# DESIGN-time intent had a final `argocd-root-app` Helm release that would
# install argo/argo-cd into the argocd namespace; that's been DROPPED — the
# CNOE ref-implementation already installs ArgoCD there, and re-installing
# collides on existing resources. See DESIGN v1.2 Reality Reconciliation §A.
# The "root app" pattern is implemented as a single Application CR pointing
# at platform/argocd/applications/, applied separately (file 26).
repositories:
  - name: grafana
    url: https://grafana.github.io/helm-charts
  - name: open-telemetry
    url: https://open-telemetry.github.io/opentelemetry-helm-charts
  - name: kyverno
    url: https://kyverno.github.io/kyverno
  - name: crossplane-stable
    url: https://charts.crossplane.io/stable
  - name: emberstack
    url: https://emberstack.github.io/helm-charts

releases:
  - name: crossplane
    namespace: crossplane-system
    createNamespace: true
    chart: crossplane-stable/crossplane
    version: "1.17.1"

  - name: kyverno
    namespace: kyverno
    createNamespace: true
    chart: kyverno/kyverno
    version: "3.2.6"
    # Cleanup CronJobs reference an upstream-removed image tag. See
    # platform/observability/kyverno-values.yaml header for context.
    values:
      - /tmp/whisperops/platform/observability/kyverno-values.yaml

  - name: lgtm-distributed
    namespace: observability
    createNamespace: true
    chart: grafana/lgtm-distributed
    version: "2.1.0"
    values:
      - /tmp/whisperops/platform/observability/lgtm-values.yaml

  - name: opentelemetry-collector
    namespace: observability
    createNamespace: true
    chart: open-telemetry/opentelemetry-collector
    version: "0.104.0"
    needs:
      - observability/lgtm-distributed
    values:
      - /tmp/whisperops/platform/observability/otel-collector-values.yaml

  # DD-73 option-C (2026-05-08): kagent chart v0.4.3 bundles CRDs in
  # templates/ alongside CRs, causing a CRD/CR ordering race on first install.
  # A separate kagent-crds chart exists at the same version and contains all
  # five CRDs (agents, memories, modelconfigs, teams, toolservers). Install it
  # first; the main kagent release lists it in `needs:` so helmfile guarantees
  # ordering. The `--server-side` equivalent is handled by helm install itself;
  # `wait: true` on the CRD release ensures Established condition before kagent.
  - name: kagent-crds
    namespace: kagent-system
    createNamespace: true
    chart: oci://ghcr.io/kagent-dev/kagent/helm/kagent-crds
    version: "0.4.3"
    wait: true
    timeout: 120

  - name: kagent
    namespace: kagent-system
    createNamespace: true
    chart: oci://ghcr.io/kagent-dev/kagent/helm/kagent
    version: "0.4.3"
    needs:
      - kagent-system/kagent-crds
    hooks:
      - events: ["presync"]
        showlogs: true
        command: bash
        args:
          - -c
          - |
            # The kagent chart hardcodes namespace: kagent on the grafana ToolServer
            # (templates/toolserver-grafana.yaml). That namespace must exist before
            # helm install attempts to create the resource or the install fails with
            # "namespaces kagent not found". kubectl apply is idempotent on re-deploy.
            sudo kubectl create namespace kagent --dry-run=client -o yaml | sudo kubectl apply -f -
    # DD-20: declarative ANTHROPIC_API_KEY env var on `app` container.
    # The Secret `anthropic-api-key` (key `api-key`) must exist in the
    # kagent-system namespace BEFORE this release reconciles — bootstrap
    # populates it from SOPS-decrypted secrets/anthropic.enc.yaml.
    # DD-64: wait for install to fully complete before helmfile exits. Without
    # this, helmfile may cache "deployed" even when the OCI pull failed or the
    # install rolled back silently. timeout matches the kagent nginx timeout.
    wait: true
    timeout: 600
    values:
      - /tmp/whisperops/platform/values/kagent-values.yaml
    # DD-72 (2026-05-08): kagent-postrender.sh disabled. Two latent bugs:
    # (1) heredoc-stdin clobbered helm's piped manifest -> empty output (fixed
    # in commits 6f22f17/a17edd0); (2) the DD-31+DD-47 regex injection then
    # produces invalid YAML at ~line 126 (helmfile sync error: "did not find
    # expected key"). Until the regex is rewritten with proper YAML parsing,
    # disabled so kagent installs cleanly. Loss: AUTOGEN_DISABLE_RUNTIME_TRACING
    # has TWO env entries (kubelet last-wins, DD-31 narrative); DD-47 nginx
    # 600s timeout reverts to 60s default.
    # postRenderer: /tmp/whisperops/platform/values/kagent-postrender.sh

  # DD-75: Reflector mirrors ar-pull-secret-source (crossplane-system) to all
  # agent-* namespaces automatically. Must be up before the first agent scaffold.
  - name: reflector
    namespace: reflector-system
    createNamespace: true
    chart: emberstack/reflector
    version: "7.1.288"
    wait: true
    timeout: 120
