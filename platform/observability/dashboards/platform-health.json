{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Platform health: cluster resources, ArgoCD sync, Crossplane reconcile, NGINX, cert expiry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "text": {},
        "textMode": "auto"
      },
      "title": "Cluster CPU Usage %",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace!=''}[5m])) / sum(kube_node_status_allocatable{resource='cpu'}) * 100",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "title": "Cluster Memory Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace!=''}) / sum(kube_node_status_allocatable{resource='memory'})",
          "legendFormat": "Memory"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "title": "ArgoCD Apps Synced",
      "type": "stat",
      "targets": [
        {
          "expr": "count(argocd_app_info{sync_status='Synced'})",
          "legendFormat": "Synced"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2592000
              },
              {
                "color": "red",
                "value": 604800
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "min"
          ]
        }
      },
      "title": "Min Cert Expiry (seconds)",
      "type": "stat",
      "targets": [
        {
          "expr": "min(certmanager_certificate_expiration_timestamp_seconds - time())",
          "legendFormat": "Min expiry"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "title": "NGINX Ingress Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests[5m])) by (ingress)",
          "legendFormat": "{{ingress}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "title": "NGINX p50/p95/p99 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "title": "Log Signals",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "title": "Cluster-Level Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(rate({namespace!~\"kube-.*\"} |= \"error\" | json | __error__=\"\" [5m]))",
          "legendFormat": "error rate"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": [
    "whisperops",
    "platform",
    "health"
  ],
  "title": "Platform Health",
  "uid": "whisperops-platform-health",
  "version": 2,
  "templating": {
    "list": [
      {
        "name": "agent_namespace",
        "type": "query",
        "label": "Agent Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "prom"
        },
        "query": "label_values(kube_namespace_labels{label_app_kubernetes_io_part_of=\"whisperops\"}, namespace)",
        "includeAll": true,
        "multi": true,
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
}
