apiVersion: storage.gcp.upbound.io/v1beta1
kind: Bucket
metadata:
  name: agent-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  forProvider:
    location: ${{ values.region | default('US-CENTRAL1') }}
    publicAccessPrevention: enforced
    uniformBucketLevelAccess: true
    # forceDestroy lets Crossplane delete the bucket + all objects (including
    # versions, since versioning is enabled) in one atomic GCP API call when
    # the Bucket CR is deleted during `make destroy`. Without it, drain-crossplane
    # would need a pre-empty pass via gcloud (the old `empty-buckets` target),
    # which races with anything writing to the bucket between empty + delete.
    forceDestroy: true
    versioning:
      - enabled: true
    labels:
      whisperops-agent: agent-${{ values.agent_name }}
      dataset: ${{ values.dataset_id }}
  providerConfigRef:
    name: default
  deletionPolicy: Delete
