apiVersion: storage.gcp.upbound.io/v1beta1
kind: Bucket
metadata:
  name: agent-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  forProvider:
    location: ${{ values.region | default('US-CENTRAL1') }}
    publicAccessPrevention: enforced
    uniformBucketLevelAccess: true
    # forceDestroy: delete bucket + objects (incl. non-current versions) atomically.
    forceDestroy: true
    versioning:
      - enabled: true
    # CORS: allow browser fetches of signed-URL artifacts (Plotly JSON charts) from the
    # chat-frontend served at https://agent-<name>.<ip>.sslip.io. Signed URLs are
    # the auth mechanism here; `*` origin is acceptable because access still requires
    # the signature. Without this, browsers block the fetch (chart fails to render
    # inline even though the JSON exists in the bucket).
    cors:
      - origin: ["*"]
        method: ["GET", "HEAD"]
        responseHeader: ["Content-Type"]
        maxAgeSeconds: 3600
    labels:
      whisperops-agent: agent-${{ values.agent_name }}
      dataset: ${{ values.dataset_id }}
  providerConfigRef:
    name: default
  deletionPolicy: Delete
