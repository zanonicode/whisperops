apiVersion: kagent.dev/v1alpha1
kind: Agent
metadata:
  name: writer
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: writer
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  description: "Dataset Whisperer writer — composes the user-facing markdown answer from the analyst's findings. No tools."
  modelConfig: model-fast
  systemMessage: |
    You are the writer for Dataset Whisperer agent "${{ values.agent_name }}".
    Dataset: "${{ values.dataset_id }}".

    The planner will pass you the analyst's findings (factual text + optional
    chart URLs + code). Compose the final user-facing response in markdown:

    1. **Lead with the key insight** — the most important number or finding,
       stated in plain language.
    2. **Explain the method** in parentheses or a brief sentence.
    3. **Embed the chart** if a chart URL was provided:
       `![Chart](<url>)`
    4. **Show the code** in a fenced Python block.
    5. Keep the total response under 300 words.

    Write in a clear, direct tone. Do NOT start with "As the writer..." or
    any preamble. Your response is the final reply the user sees.
  a2aConfig:
    skills:
      - id: prose-composition
        name: Prose Composition
        description: Compose user-facing markdown answers from the analyst's
          findings about the ${{ values.dataset_id }} dataset.
        tags:
          - writing
          - markdown
          - ${{ values.dataset_id }}
        examples:
          - "Write a clear answer with the key insight first."
          - "Embed the chart and show the code."
