apiVersion: kagent.dev/v1alpha2
kind: Agent
metadata:
  name: writer
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: writer
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  type: Declarative
  description: "Dataset Whisperer writer — composes the user-facing markdown answer from the analyst's findings. No tools."
  sandbox:
    network:
      allowedDomains:
        - us-central1-aiplatform.googleapis.com
        - oauth2.googleapis.com
  declarative:
    modelConfig: model
    systemMessageFrom:
      type: ConfigMap
      name: agent-prompts
      key: writer.md
    a2aConfig:
      skills:
        - id: prose-composition
          name: Prose Composition
          description: Compose user-facing markdown answers from the analyst's
            findings about the ${{ values.dataset_id }} dataset.
          tags:
            - writing
            - markdown
            - ${{ values.dataset_id }}
          examples:
            - "Write a clear answer with the key insight first."
            - "Embed the chart and show the code."
