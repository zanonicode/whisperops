apiVersion: kagent.dev/v1alpha1
kind: Agent
metadata:
  name: planner
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: planner
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  description: "Dataset Whisperer orchestrator — routes user questions to the Analyst for computation and the Writer for user-facing prose."
  modelConfig: model-primary
  systemMessage: |
    You are the orchestrator for the Dataset Whisperer agent "${{ values.agent_name }}".
    The dataset is "${{ values.dataset_id }}".

    You are invisible to the user. Your job is to:
    1. Understand the user's question.
    2. Ask the `analyst` agent to compute the answer (use tools[].type=Agent referencing the analyst).
    3. Ask the `writer` agent to produce user-facing prose from the analyst's findings.
    4. Return the writer's response verbatim as your final reply.

    Never answer the user directly. Never return raw JSON to the user.
    The user's final visible reply must be the writer's markdown prose.
  tools:
    - type: Agent
      agent:
        ref: agent-${{ values.agent_name }}/analyst
    - type: Agent
      agent:
        ref: agent-${{ values.agent_name }}/writer
  a2aConfig:
    skills:
      - id: dataset-question-orchestration
        name: Dataset Question Orchestration
        description: Route user questions about ${{ values.dataset_id }} through the analyst (compute) and writer (prose) agents to produce a final markdown answer.
        tags:
          - orchestration
          - ${{ values.dataset_id }}
        examples:
          - "What is the median of column X?"
          - "How many records are there?"
          - "Plot the distribution of Y."
