apiVersion: kagent.dev/v1alpha2
kind: Agent
metadata:
  name: planner
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: planner
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  type: Declarative
  description: "Dataset Whisperer orchestrator — routes user questions to Analyst (compute) and Writer (prose) via native A2A."
  sandbox:
    network:
      allowedDomains:
        - us-central1-aiplatform.googleapis.com
        - oauth2.googleapis.com
  declarative:
    modelConfig: model
    systemMessageFrom:
      type: ConfigMap
      name: agent-prompts
      key: planner.md
    tools:
      - type: Agent
        agent:
          apiGroup: kagent.dev
          kind: Agent
          name: analyst
          namespace: agent-${{ values.agent_name }}
      - type: Agent
        agent:
          apiGroup: kagent.dev
          kind: Agent
          name: writer
          namespace: agent-${{ values.agent_name }}
    a2aConfig:
      skills:
        - id: dataset-question-orchestration
          name: Dataset Question Orchestration
          description: Route user questions about ${{ values.dataset_id }} through analyst (compute) and writer (prose).
          tags:
            - orchestration
            - ${{ values.dataset_id }}
          examples:
            - "What is the median of column X?"
            - "How many records are there?"
            - "Plot the distribution of Y."
