apiVersion: kagent.dev/v1alpha2
kind: Agent
metadata:
  name: planner
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: planner
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  type: Declarative
  description: "Dataset Whisperer router — classifies user messages and routes analytical questions to the Worker. Handles conversational replies (greetings, off-topic, meta-questions) directly."
  sandbox:
    network:
      allowedDomains:
        - us-central1-aiplatform.googleapis.com
        - oauth2.googleapis.com
  declarative:
    modelConfig: model
    systemMessageFrom:
      type: ConfigMap
      name: agent-prompts
      key: planner.md
    tools:
      - type: Agent
        agent:
          apiGroup: kagent.dev
          kind: Agent
          name: worker
          namespace: agent-${{ values.agent_name }}
    a2aConfig:
      skills:
        - id: dataset-question-orchestration
          name: Dataset Question Routing
          description: Classify and route user questions about ${{ values.dataset_id }}. Forward analytical questions to the worker; handle greetings, off-topic, and meta-questions directly.
          tags:
            - orchestration
            - routing
            - ${{ values.dataset_id }}
          examples:
            - "What is the median of column X?"
            - "How many records are there?"
            - "Plot the distribution of Y."
            - "Hi, what can you do?"
            - "What did I ask first in this conversation?"
