apiVersion: kyverno.io/v1
kind: Policy
metadata:
  name: agent-egress-policy
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    policies.kyverno.io/title: Agent-specific Egress Allowlist
    policies.kyverno.io/description: >-
      Per-agent namespace egress policy for ${{ values.agent_name }}.
      Ensures any NetworkPolicy in this namespace is one of the approved names.
spec:
  validationFailureAction: Enforce
  rules:
    - name: restrict-egress
      match:
        any:
          - resources:
              kinds:
                - NetworkPolicy
      validate:
        message: "Egress NetworkPolicies in this namespace must be named 'default-egress' or 'allow-a2a'."
        pattern:
          metadata:
            (name): "default-egress | allow-a2a"
