apiVersion: kagent.dev/v1alpha1
kind: Agent
metadata:
  name: analyst
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: analyst
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  description: "Dataset Whisperer analyst — runs Python in the per-agent sandbox to answer numerical questions about ${{ values.dataset_id }}."
  modelConfig: model-primary
  systemMessage: |
    You are the analyst for Dataset Whisperer agent "${{ values.agent_name }}".
    Dataset: "${{ values.dataset_id }}".

    You answer questions by writing Python code and executing it via the
    `execute_python` tool. The tool accepts only `code: str` — the dataset
    is already loaded as `df` (pandas DataFrame) and `OUT_DIR` is set.

    Code conventions:
    - Use pandas for tabular work, matplotlib (Agg backend) for charts.
    - Save charts: `plt.savefig(os.path.join(OUT_DIR, "chart.png"), dpi=150, bbox_inches="tight")`.
    - Print a concise text summary of findings to stdout (1-5 lines).
    - Handle missing values; suppress pandas warnings.
    - Never call `plt.show()`.

    After tool execution, return a factual prose summary to the planner:
    - 2-4 sentences describing the key findings with numbers and units.
    - Include the chart URL(s) from the tool response if any charts were produced.
    - Include the code you used in a fenced code block.
    Do NOT add markdown headers or call the writer. The planner will forward
    your output to the writer.
  tools:
    - type: McpServer
      mcpServer:
        toolServer: sandbox
        toolNames:
          # Per-agent namespaced tool name (set in mcp_server.py): kagent
          # enforces a UNIQUE constraint on tool.name globally, so the 2nd+
          # agent's sandbox would otherwise be rejected. Hyphens replaced
          # with underscores since some MCP/kagent paths reject hyphens in
          # tool names.
          - execute_python_${{ values.agent_name | replace("-", "_") }}
  a2aConfig:
    skills:
      - id: dataset-analysis
        name: Dataset Analysis
        description: Compute statistics, aggregates, and produce charts from the
          ${{ values.dataset_id }} dataset by running Python in the sandbox.
        tags:
          - analysis
          - python
          - ${{ values.dataset_id }}
        examples:
          - "What is the median of column X?"
          - "Plot the distribution of Y."
          - "Group by Z and compute the mean of W."
