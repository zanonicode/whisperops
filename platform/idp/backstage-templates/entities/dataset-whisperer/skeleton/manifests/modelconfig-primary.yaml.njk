apiVersion: kagent.dev/v1alpha1
kind: ModelConfig
metadata:
  name: model-primary
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  provider: Anthropic
  # Hardcoded: Haiku 4.5 is not function-call-capable under the autogen
  # version pinned by kagent. Reintroduce a model dropdown only when the
  # autogen registry classifies additional models as function-calling-capable.
  model: claude-sonnet-4-5-20250929
  apiKeySecretRef: anthropic-api-key
  apiKeySecretKey: api-key
  anthropic:
    maxTokens: 1024
    temperature: "0"
