apiVersion: apps/v1
kind: Deployment
metadata:
  name: chat-frontend-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "4"
  labels:
    app: chat-frontend
    whisperops.io/agent: agent-${{ values.agent_name }}
    whisperops.io/component: chat-frontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: chat-frontend
      whisperops.io/agent: agent-${{ values.agent_name }}
  template:
    metadata:
      labels:
        app: chat-frontend
        whisperops.io/agent: agent-${{ values.agent_name }}
        whisperops.io/component: chat-frontend
    spec:
      automountServiceAccountToken: false
      imagePullSecrets:
        - name: ar-pull-secret
      containers:
        - name: chat-frontend
          image: us-central1-docker.pkg.dev/${{ values.project_id }}/whisperops-images/chat-frontend:latest
          imagePullPolicy: Always
          ports:
            - name: http
              containerPort: 3000
              protocol: TCP
          env:
            - name: PLANNER_URL
              value: "http://planner.agent-${{ values.agent_name }}.svc.cluster.local:8080"
            - name: AGENT_NAME
              value: "${{ values.agent_name }}"
            - name: STREAMING_ENABLED
              value: "true"
            - name: NODE_ENV
              value: "production"
            - name: OTEL_EXPORTER_OTLP_ENDPOINT
              value: "http://otel-collector.observability.svc.cluster.local:4318"
            - name: OTEL_SERVICE_NAME
              value: "chat-frontend-${{ values.agent_name }}"
            - name: OTEL_RESOURCE_ATTRIBUTES
              value: "whisperops.agent=${{ values.agent_name }},deployment.environment=production"
          readinessProbe:
            httpGet:
              path: /api/health
              port: 3000
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 3
          livenessProbe:
            httpGet:
              path: /api/health
              port: 3000
            initialDelaySeconds: 15
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          securityContext:
            runAsNonRoot: true
            runAsUser: 1000
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
---
apiVersion: v1
kind: Service
metadata:
  name: chat-frontend-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "4"
  labels:
    whisperops.io/agent: agent-${{ values.agent_name }}
    whisperops.io/component: chat-frontend
spec:
  type: ClusterIP
  selector:
    app: chat-frontend
    whisperops.io/agent: agent-${{ values.agent_name }}
  ports:
    - port: 3000
      targetPort: 3000
      protocol: TCP
      name: http
