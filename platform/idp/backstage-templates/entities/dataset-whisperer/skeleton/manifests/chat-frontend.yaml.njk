# Per-agent chat UI: a Next.js app that talks directly to kagent's session
# API and streams responses back to the browser. Scoped to ONE agent (the
# planner of this scaffolded app) via env vars.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: chat-frontend-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
  labels:
    app: chat-frontend
    whisperops.io/agent: agent-${{ values.agent_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: chat-frontend
      whisperops.io/agent: agent-${{ values.agent_name }}
  template:
    metadata:
      labels:
        app: chat-frontend
        whisperops.io/agent: agent-${{ values.agent_name }}
    spec:
      automountServiceAccountToken: false
      imagePullSecrets:
        - name: ar-pull-secret
      containers:
        - name: chat-frontend
          image: us-central1-docker.pkg.dev/${{ values.project_id }}/whisperops-images/chat-frontend:latest
          # :latest + IfNotPresent caches the first pulled digest and never
          # re-pulls on rebuilds. Always-pull until images move to immutable
          # content-hash tags.
          imagePullPolicy: Always
          ports:
            - name: http
              containerPort: 3000
              protocol: TCP
          env:
            - name: KAGENT_BASE_URL
              value: "http://kagent.kagent-system.svc.cluster.local"
            - name: AGENT_NAMESPACE
              value: "agent-${{ values.agent_name }}"
            - name: AGENT_NAME
              value: "planner"
            - name: USER_ID
              value: "demo@whisperops"
            - name: NEXT_PUBLIC_OTEL_ENDPOINT
              value: "http://otel-collector.observability:4318"
            - name: NODE_ENV
              value: "production"
          readinessProbe:
            httpGet:
              path: /
              port: 3000
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /
              port: 3000
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          securityContext:
            runAsNonRoot: true
            runAsUser: 1000
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
---
apiVersion: v1
kind: Service
metadata:
  name: chat-frontend-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
  labels:
    whisperops.io/agent: agent-${{ values.agent_name }}
spec:
  type: ClusterIP
  selector:
    app: chat-frontend
    whisperops.io/agent: agent-${{ values.agent_name }}
  ports:
    - port: 3000
      targetPort: 3000
      protocol: TCP
      name: http
