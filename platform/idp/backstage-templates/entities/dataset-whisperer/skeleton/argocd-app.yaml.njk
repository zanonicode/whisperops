apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: agent-${{ values.agent_name }}
  namespace: argocd
  annotations:
    argocd.argoproj.io/sync-wave: "0"
  labels:
    whisperops.io/agent: agent-${{ values.agent_name }}
    whisperops.io/dataset: ${{ values.dataset_id }}
spec:
  project: default
  source:
    # CNOE-vendored Gitea uses giteaAdmin as the owner of repos created by
    # the scaffolder (publish:gitea action). Each agent gets its own repo
    # at giteaAdmin/agent-{name}; manifests live at the repo root.
    repoURL: https://gitea.gitea.svc.cluster.local:3000/giteaAdmin/agent-${{ values.agent_name }}.git
    targetRevision: HEAD
    path: .
    directory:
      recurse: true
      exclude: '{catalog-info.yaml,argocd-app.yaml,README.md}'
  destination:
    server: https://kubernetes.default.svc
    namespace: agent-${{ values.agent_name }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
