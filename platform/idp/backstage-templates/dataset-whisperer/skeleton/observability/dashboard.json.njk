{
  "title": "Agent ${{values.agent_name}} — Detail (${{values.dataset_id}})",
  "uid": "agent-${{values.agent_name}}-detail",
  "tags": ["agent", "${{values.agent_name}}", "${{values.dataset_id}}"],
  "description": "Per-agent observability dashboard. Agent: ${{values.agent_name}}, Dataset: ${{values.dataset_id}}, Budget: ${{values.budget_usd}} USD.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "agent",
        "type": "constant",
        "label": "Agent",
        "current": {
          "selected": true,
          "text": "${{values.agent_name}}",
          "value": "${{values.agent_name}}"
        },
        "hide": 2,
        "query": "${{values.agent_name}}"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Availability (chat-frontend, this agent)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.98 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(http_requests_total{service=\"chat-frontend\",agent_name=\"$agent\",code!~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"chat-frontend\",agent_name=\"$agent\"}[5m]))",
          "legendFormat": "availability"
        }
      ]
    },
    {
      "id": 2,
      "title": "TTFT p95 (this agent, s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chat_frontend_ttft_seconds_bucket{agent_name=\"$agent\"}[5m])))",
          "legendFormat": "p95 TTFT"
        }
      ]
    },
    {
      "id": 3,
      "title": "Budget Utilization %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "whisperops_spend_usd:cumulative{agent_name=\"$agent\"} / on(agent_name) whisperops_agent_budget_usd{agent_name=\"$agent\"}",
          "legendFormat": "budget used"
        }
      ]
    },
    {
      "id": 4,
      "title": "Apdex Score (T=10s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "chat_frontend:apdex_score:rate5m{agent_name=\"$agent\"}",
          "legendFormat": "apdex"
        }
      ]
    },
    {
      "id": 5,
      "title": "Sandbox executions by outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (outcome) (rate(sandbox_executions_total{namespace=\"$agent\"}[5m]))",
          "legendFormat": "{{ outcome }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token usage (input / output / cached)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(whisperops_tokens_input_total{agent_name=\"$agent\"}[5m]) * 60",
          "legendFormat": "input/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(whisperops_tokens_output_total{agent_name=\"$agent\"}[5m]) * 60",
          "legendFormat": "output/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(whisperops_tokens_cached_input_total{agent_name=\"$agent\"}[5m]) * 60",
          "legendFormat": "cached/min"
        }
      ]
    },
    {
      "id": 9,
      "title": "Sandbox executions / turn",
      "description": "Worker's stderr-retry loop fires up to 3× per turn. Healthy ratio is ~1.0–1.3. Sustained >2.0 → prompt regression or worker mis-coding patterns the dataset.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sandbox_executions_per_turn:ratio{agent_name=\"$agent\"}",
          "legendFormat": "ratio"
        }
      ]
    },
    {
      "id": 10,
      "title": "Sandbox p95 duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 45 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sandbox_duration_bucket{namespace=\"$agent\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 11,
      "title": "Sandbox OOMs (per hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(sandbox_oom_total{namespace=\"$agent\"}[5m])) * 3600",
          "legendFormat": "OOM/h"
        }
      ]
    },
    {
      "id": 12,
      "title": "Sandbox timeouts (per hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(sandbox_timeouts_total{namespace=\"$agent\"}[5m])) * 3600",
          "legendFormat": "timeout/h"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pod logs (this agent namespace, last 1h)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=\"$agent\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "title": "Trace search (this agent)",
      "type": "traces",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.agent_name=\"$agent\"}"
        }
      ]
    }
  ]
}
