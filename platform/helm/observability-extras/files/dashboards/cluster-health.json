{
  "title": "D1 — Cluster Health (USE Method)",
  "uid": "whisperops-cluster-health",
  "tags": ["cluster", "use-method", "node-exporter", "kube-state-metrics"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU Utilization %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Node Memory Utilization %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node Disk Utilization %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Rx/Tx (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "rx {{ device }}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "tx {{ device }}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pod Phase Distribution",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (phase) (kube_pod_status_phase)",
          "legendFormat": "{{ phase }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Deployment Replicas Available vs Desired",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (deployment) (kube_deployment_status_replicas_available)",
          "legendFormat": "available: {{ deployment }}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (deployment) (kube_deployment_spec_replicas)",
          "legendFormat": "desired: {{ deployment }}"
        }
      ]
    }
  ]
}
