          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"agent-.+\" && resource.k8s.namespace.name=~\"$agent_namespace\" } | select(duration)",
