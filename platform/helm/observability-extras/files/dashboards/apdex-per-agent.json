{
  "title": "D8 — Apdex per Agent (T=10s, tolerable=40s)",
  "uid": "whisperops-apdex",
  "tags": ["apdex", "ttft", "latency", "slo"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Apdex Score per Agent (T=10s; tolerable le=30s approximates 40s per ADR-Obs-12)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "chat_frontend:apdex_score:rate5m",
          "legendFormat": "Apdex: {{ agent_name }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Satisfied (TTFT ≤ 10s) requests/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "chat_frontend:apdex_satisfied:rate5m * 60",
          "legendFormat": "satisfied: {{ agent_name }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tolerable (10s < TTFT ≤ 30s) requests/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "chat_frontend:apdex_tolerable:rate5m * 60",
          "legendFormat": "tolerable: {{ agent_name }}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Frustrated (TTFT > 30s proxy for >40s) requests/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "(chat_frontend:apdex_total:rate5m - chat_frontend:apdex_satisfied:rate5m - chat_frontend:apdex_tolerable:rate5m) * 60",
          "legendFormat": "frustrated: {{ agent_name }}"
        }
      ]
    }
  ]
}
