{
  "title": "D4 — SLO Compliance",
  "uid": "whisperops-slo-compliance",
  "tags": ["slo", "error-budget", "mwmbr"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "60s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Chat-Frontend Availability SLO (99%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.98 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "min(chat_frontend:availability:ratio_rate_1h)",
          "legendFormat": "availability"
        }
      ]
    },
    {
      "id": 2,
      "title": "Chat-Frontend TTFT SLO (95% ≤ 10s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "min(chat_frontend:ttft_slo_ratio:rate_5m)",
          "legendFormat": "% requests ≤ 10s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Sandbox Success SLO (99%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.98 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "min(sandbox_executions:success_ratio_rate_5m)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Vertex Availability SLO (95%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "vertex:availability:ratio_rate_5m",
          "legendFormat": "vertex availability"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Budget Burn Rate (chat-frontend availability, 5m window)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "(1 - chat_frontend:availability:ratio_rate_5m) / (1 - 0.99)",
          "legendFormat": "burn rate: {{ agent_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active SLO Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "ALERTS{alertstate=\"firing\",slo!=\"\"}",
          "legendFormat": "{{ alertname }} — {{ agent_name }}"
        }
      ]
    }
  ]
}
