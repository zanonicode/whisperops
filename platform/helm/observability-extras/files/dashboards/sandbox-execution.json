{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Sandbox execution: concurrency, queue depth, timeout/OOM rates, artifact upload latency",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Concurrent Executions",
      "type": "stat",
      "targets": [{ "expr": "sandbox_concurrent_executions", "legendFormat": "Concurrent" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Timeout Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(sandbox_timeouts_total[10m]) / rate(sandbox_executions_total[10m])", "legendFormat": "Timeout rate" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "OOM Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(sandbox_oom_total[10m]) / rate(sandbox_executions_total[10m])", "legendFormat": "OOM rate" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 1 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "title": "Execution Duration p50/p95/p99",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sandbox_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(sandbox_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(sandbox_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 1 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "title": "Artifact Upload Latency p95",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(sandbox_upload_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Upload p95" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "title": "Structured Logs — Loki",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Rate", "desc": true }]
      },
      "title": "Error Rate by Message (last 1h)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level, msg) (rate({namespace=~\"agent-.*\", app=\"sandbox\"} |= \"error\" | json | __error__=\"\" [5m]))",
          "legendFormat": "{{level}} — {{msg}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Sandbox Log Stream",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=~\"agent-.*\", app=\"sandbox\"} | json",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["whisperops", "sandbox", "execution"],
  "title": "Sandbox Execution",
  "uid": "whisperops-sandbox-execution",
  "version": 1
}
