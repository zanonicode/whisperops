apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: agent-${{ values.agent_name }}
  namespace: argocd
  annotations:
    argocd.argoproj.io/sync-wave: "0"
  labels:
    whisperops.io/agent: agent-${{ values.agent_name }}
    whisperops.io/dataset: ${{ values.dataset_id }}
spec:
  project: default
  source:
    repoURL: http://gitea.gitea.svc.cluster.local/whisperops/agents.git
    targetRevision: HEAD
    path: ${{ values.agent_name }}
    directory:
      recurse: true
  destination:
    server: https://kubernetes.default.svc
    namespace: agent-${{ values.agent_name }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
