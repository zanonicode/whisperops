apiVersion: kagent.dev/v1
kind: Agent
metadata:
  name: planner
  namespace: agent-{{ values.agent_name }}-{{ values.suffix }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "{{ values.budget_usd | default('5.00') }}"
    whisperops.io/role: planner
spec:
  model:
    provider: anthropic
    modelId: claude-haiku-4-5-20251001
  systemPromptConfigMapRef:
    name: prompt-planner
    namespace: whisperops-system
  observability:
    otlpEndpoint: http://otel-collector.observability:4317
    tags:
      - agent-{{ values.agent_name }}-{{ values.suffix }}
      - dataset:{{ values.dataset_id }}
      - role:planner
