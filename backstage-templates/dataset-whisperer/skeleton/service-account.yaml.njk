apiVersion: cloudplatform.gcp.upbound.io/v1beta1
kind: ServiceAccount
metadata:
  name: agent-{{ values.agent_name }}-{{ values.suffix }}
  namespace: agent-{{ values.agent_name }}-{{ values.suffix }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  forProvider:
    displayName: "Dataset Whisperer Agent: {{ values.agent_name }}-{{ values.suffix }}"
    description: "Service account for agent-{{ values.agent_name }}-{{ values.suffix }}"
  providerConfigRef:
    name: default
