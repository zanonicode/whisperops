apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: agent-${{ values.agent_name }}
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
    cert-manager.io/cluster-issuer: letsencrypt-prod
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    # Chart-generation queries can take 60-180s (LLM planner + LLM analyst +
    # matplotlib render + LLM writer). 300s was the prior default and caused
    # 504s on a successful end-to-end smoke. Bumped to 600s. Also disable
    # response buffering so SSE streams to the browser without batching.
    nginx.ingress.kubernetes.io/proxy-read-timeout: "600"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "600"
    nginx.ingress.kubernetes.io/proxy-buffering: "off"
    nginx.ingress.kubernetes.io/proxy-http-version: "1.1"
  labels:
    whisperops.io/agent: agent-${{ values.agent_name }}
spec:
  ingressClassName: nginx
  rules:
    - host: agent-${{ values.agent_name }}.${{ values.base_domain | default('sslip.io') }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: chat-frontend-${{ values.agent_name }}
                port:
                  number: 3000
  tls:
    - secretName: agent-${{ values.agent_name }}-tls
      hosts:
        - agent-${{ values.agent_name }}.${{ values.base_domain | default('sslip.io') }}
