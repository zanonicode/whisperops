apiVersion: cloudplatform.gcp.upbound.io/v1beta1
kind: ServiceAccountKey
metadata:
  name: agent-${{ values.agent_name }}-key
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  forProvider:
    serviceAccountRef:
      name: agent-${{ values.agent_name }}
  writeConnectionSecretToRef:
    namespace: agent-${{ values.agent_name }}
    name: gcp-sa-key
  providerConfigRef:
    name: default
