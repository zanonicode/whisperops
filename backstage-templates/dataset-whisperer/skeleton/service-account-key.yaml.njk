apiVersion: cloudplatform.gcp.upbound.io/v1beta1
kind: ServiceAccountKey
metadata:
  name: agent-{{ values.agent_name }}-{{ values.suffix }}-key
  namespace: agent-{{ values.agent_name }}-{{ values.suffix }}
  annotations:
    argocd.argoproj.io/sync-wave: "1"
spec:
  forProvider:
    serviceAccountRef:
      name: agent-{{ values.agent_name }}-{{ values.suffix }}
  writeConnectionSecretToRef:
    namespace: agent-{{ values.agent_name }}-{{ values.suffix }}
    name: gcp-sa-key
  providerConfigRef:
    name: default
