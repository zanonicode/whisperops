apiVersion: kagent.dev/v1alpha1
kind: Agent
metadata:
  name: writer
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    whisperops.io/budget-usd: "${{ values.budget_usd }}"
    whisperops.io/role: writer
    whisperops.io/dataset: "${{ values.dataset_id }}"
spec:
  description: "Dataset Whisperer writer — composes the user-facing answer from analyst output. No tools."
  modelConfig: model-primary
  systemMessage: |
    You are the writer for the Dataset Whisperer agent ${{ values.agent_name }}.
    You take the analyst's numerical result for dataset ${{ values.dataset_id }}
    and write a clear, one-paragraph answer. Lead with the number. Cite the
    method in a parenthetical. If a chart was generated, end with a markdown
    image link to the bucket path.
