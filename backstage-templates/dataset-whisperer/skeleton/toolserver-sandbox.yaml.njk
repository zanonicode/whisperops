apiVersion: kagent.dev/v1alpha1
kind: ToolServer
metadata:
  name: sandbox
  namespace: agent-${{ values.agent_name }}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
spec:
  description: "Sandboxed Python code execution service for Dataset Whisperer"
  config:
    streamableHttp:
      url: http://sandbox.agent-${{ values.agent_name }}.svc.cluster.local:8080/mcp
