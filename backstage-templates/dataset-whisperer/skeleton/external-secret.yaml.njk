apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: gcp-sa-key-synced
  namespace: agent-{{ values.agent_name }}-{{ values.suffix }}
  annotations:
    argocd.argoproj.io/sync-wave: "0"
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: cluster-secret-store
    kind: ClusterSecretStore
  target:
    name: gcp-sa-key-synced
    creationPolicy: Owner
    template:
      type: Opaque
      data:
        sa-key.json: "{{ `{{.sa_key_json}}` }}"
        sa-key-b64: "{{ `{{.sa_key_json | b64enc}}` }}"
  dataFrom:
    - sourceRef:
        generatorRef:
          apiVersion: generators.external-secrets.io/v1alpha1
          kind: Password
          name: gcp-sa-key
      rewrite:
        - regexp:
            source: "(.*)"
            target: "sa_key_json"
